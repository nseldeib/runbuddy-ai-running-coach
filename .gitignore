# Per-clone session start state (sessionId/startedAtSha), read only locally by
# the authorship check — never read from a commit, so it must not be shared.
# Tracking it makes it conflict on every rebase; untracking removes the problem.
.codeyam/session-marker.json
.codeyam/editor.local.json
.codeyam/cloud.json
